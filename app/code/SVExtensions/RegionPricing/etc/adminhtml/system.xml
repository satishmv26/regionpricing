                    <label>Enable Region Pricing</label>

                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>

                </field>

                <field id="default_region" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">

                    <label>Default Guest Region</label>

                    <source_model>SVExtensions\RegionPricing\Model\Config\Source\Region</source_model>

                </field>

                <field id="enable_logging" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">

                    <label>Enable Logging</label>

                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>

                </field>

            </group>

        </section>

