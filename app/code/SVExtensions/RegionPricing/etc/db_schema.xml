<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
        <table name="sv_region" resource="default" engine="innodb" comment="Region Master">

                <column xsi:type="int" name="region_id" unsigned="true" nullable="false" identity="true" comment="Region ID"/>

                <column xsi:type="varchar" name="name" length="100" nullable="false" comment="Region Name"/>

                <column xsi:type="varchar" name="code" length="20" nullable="false" comment="Region Code"/>

                <column xsi:type="varchar" name="currency_code" length="3" nullable="false" comment="Currency Code"/>

                <column xsi:type="smallint" name="status" unsigned="true" nullable="false" default="1" comment="Status"/>

                <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>

                <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>

                <constraint xsi:type="primary" referenceId="PRIMARY">
                        <column name="region_id"/>
                </constraint>

                <constraint xsi:type="unique" referenceId="SV_REGION_CODE_UNQ">
                        <column name="code"/>
                </constraint>

                <index referenceId="SV_REGION_STATUS_IDX" indexType="btree">
                        <column name="status"/>
                </index>

        </table>

        <table name="sv_product_region_price" resource="default" engine="innodb" comment="Product Region Prices">

                <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>

                <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>

                <column xsi:type="int" name="region_id" unsigned="true" nullable="false" comment="Region ID"/>

                <column xsi:type="decimal" name="price" precision="12" scale="4" nullable="false" comment="Regional Price"/>

                <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>

                <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>

                <constraint xsi:type="primary" referenceId="PRIMARY">
                        <column name="entity_id"/>
                </constraint>

                <constraint xsi:type="unique" referenceId="SV_PRODUCT_REGION_UNQ">
                        <column name="product_id"/>
                        <column name="region_id"/>
                </constraint>

                <constraint xsi:type="foreign" referenceId="SV_PRODUCT_REGION_PRODUCT_FK" table="sv_product_region_price" column="product_id" referenceTable="catalog_product_entity" referenceColumn="entity_id" onDelete="CASCADE"/>

                <constraint xsi:type="foreign" referenceId="SV_PRODUCT_REGION_REGION_FK" table="sv_product_region_price" column="region_id" referenceTable="sv_region" referenceColumn="region_id" onDelete="CASCADE"/>

                <index referenceId="SV_PRODUCT_REGION_PRODUCT_IDX" indexType="btree">
                        <column name="product_id"/>
                </index>

                <index referenceId="SV_PRODUCT_REGION_REGION_IDX" indexType="btree">
                        <column name="region_id"/>
                </index>

        </table>

</schema>