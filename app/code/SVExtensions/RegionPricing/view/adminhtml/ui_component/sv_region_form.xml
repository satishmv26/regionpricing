<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">sv_region_form.sv_region_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Region</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="SVExtensions\RegionPricing\Block\Adminhtml\Region\Edit\BackButton"/>
            <button name="delete" class="SVExtensions\RegionPricing\Block\Adminhtml\Region\Edit\DeleteButton"/>
            <button name="save" class="SVExtensions\RegionPricing\Block\Adminhtml\Region\Edit\SaveButton"/>
        </buttons>
        <namespace>sv_region_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>sv_region_form.sv_region_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="sv_region_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="svregion/region/save"/>
        </settings>
        <dataProvider class="SVExtensions\RegionPricing\Ui\DataProvider\Region\Form\DataProvider"
                      name="sv_region_form_data_source">
            <settings>
                <requestFieldName>region_id</requestFieldName>
                <primaryFieldName>region_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">Region Information</label>
        </settings>
        <field name="region_id" formElement="hidden">
            <settings>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="name" sortOrder="10" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Name</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="code" sortOrder="20" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Code</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="currency_code" sortOrder="30" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Currency</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-length" xsi:type="string">3</rule>
                </validation>
            </settings>
        </field>
        <field name="status" sortOrder="40" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Status</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Enabledisable"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>
