<?php /** @var \SVExtensions\RegionPricing\Block\Customer\RegionField $block */ if (!$block->isEnabled()) { return; } $regions = $block->getRegions(); $currentValue = $block->getCustomerRegionId(); ?> <div class="field sv-region-id required"><label class="label" for="<?= $block->escapeHtmlAttr($block->getFieldId()) ?>"><?= $block->escapeHtml(__('Pricing Region')) ?></label> <div class="control"><select name="<?= $block->escapeHtmlAttr($block->getFieldName()) ?>" id="<?= $block->escapeHtmlAttr($block->getFieldId()) ?>" class="validate-select" data-validate="{required:true}"><option value=""><?= $block->escapeHtml(__('Select Region')) ?></option><?php foreach ($regions as $region): ?> <option value="<?= $block->escapeHtmlAttr($region->getRegionId()) ?>" <?= $region->getRegionId() === $currentValue ? 'selected' : '' ?>><?= $block->escapeHtml($region->getName()) ?> (<?= $block->escapeHtml($region->getCode()) ?>)</option><?php endforeach; ?></select></div></div>